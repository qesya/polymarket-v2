# ══════════════════════════════════════════════════════════
# Polymarket AI Trading System — Environment Configuration
# Copy to .env and fill in your values. Never commit .env!
# ══════════════════════════════════════════════════════════

# ── Infrastructure ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://trader:changeme@localhost:5432/polymarket
POSTGRES_PASSWORD=changeme
CHROMA_URL=http://localhost:8000

# ── Anthropic (Claude) ────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Polymarket ────────────────────────────────────────────
# REST API key from Polymarket dashboard
POLYMARKET_API_KEY=
# EVM private key for on-chain order signing (optional for read-only)
POLYMARKET_PRIVATE_KEY=

# ── Twitter/X API ─────────────────────────────────────────
# Bearer token from developer.twitter.com
# Free tier: 500k tokens/month read-only
TWITTER_BEARER_TOKEN=

# ── Reddit API ────────────────────────────────────────────
# Create app at reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── News API ──────────────────────────────────────────────
# NewsAPI.org — free tier: 100 req/day developer, $449/mo business
NEWSAPI_KEY=

# ── Monitoring ───────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Risk Parameters (override defaults) ──────────────────
# Leave blank to use defaults from core/config.py
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.05
MAX_DRAWDOWN_PCT=0.20
MIN_EDGE_THRESHOLD=0.04
MIN_CONFIDENCE_THRESHOLD=0.60
